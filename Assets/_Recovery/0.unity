  m_Script: {fileID: 11500000, guid: 90fb537b6042fd55be7899ba5c939f45, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  _englishVersion: 'This game uses voice chat. Using the push-to-talk keys (default
    "Q" and "V") will capture your microphone input and transmit it to other users
    connected to the server.

    Certain game features may temporarily store short
    samples of your transmissions, which will be automatically erased after disconnecting
    from the server.'
  _fileId: 4
  _line: 6
