      m_Calls: []
  m_text: 'This game uses voice chat. Using the push-to-talk keys (default "Q" and
    "V") will capture your microphone input and transmit it to other users connected
    to the server.

    Certain game features may temporarily store short samples
    of your transmissions, which will be automatically erased after disconnecting
    from the server.'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 6a68ff3fe1388014f9145c29623b41dc, type: 2}
