--- !u!114 &427
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 127}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 257612d6fdf4f5b7a930bc18f18d7bdb, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  MenuActionKey: 19
  _targetRoot: {fileID: 130}
  hints:
  - name: GIVE
    shortDesc: adds item to the inventory
    fullDesc: "adds item to the inventory\n\nSYNTAX:\n\tGIVE <i>ITEMID</i>\nWHERE:\n\tITEMID
      is the identification number of the item\n\nNOTE:\n\tCheck \"ITEMLIST\" to
      display a list of item IDs."
  - name: ITEMLIST
    shortDesc: displays a list of Item IDs
    fullDesc: "displays a list of Item IDs\n\nSYNTAX:\n\tITEMLIST <i>PAGENUMBER</i>\nWHERE:\n\tPAGENUMBER
      is an integer specifying the page number"
  - name: CLEAR
    shortDesc: clears the console screen
    fullDesc: "clears the console screen\n\nSYNTAX:\n\tCLEAR\n\nNOTE:\n\t-You can
      use the \"CLS\" command as well"
  - name: QUIT
    shortDesc: terminates the game process
    fullDesc: "terminates the game process\n\nSYNTAX:\n\tQUIT\n\nNOTE:\n\t-You can
      use the \"EXIT\" command as well"
  - name: REFRESHFIX
    shortDesc: changes the console refresh mode
    fullDesc: "changes the console refresh mode\n\nSYNTAX:\n\tREFRESHFIX\n\nNOTE:\n\tThere
      are two refreshing modes:\n\t-Optimized - Smart refreshing only when it's necessary\n\t-Fixed
      - Refresh with every frame of the screen"
  - name: VALUE
    shortDesc: Displays the value of the variable giving its hidden code
    fullDesc: "Displays the value of the variable giving its hidden code\n\nSYNTAX:\n\tVALUE
      <i>VARID</i>\nWHERE:\n\tVARID is hidden variable code"
  - name: SEED
    shortDesc: Displays the map seed
    fullDesc: "Displays the map seed\n\nSYNTAX:\n\tSEED"
  - name: SHOWRIDS
    shortDesc: switches the RIDS display mode
    fullDesc: "switches the RIDS display mode\n\nSYNTAX:\n\tSHOWRIDS"
  - name: FORCECLASS
    shortDesc: forces a class change
    fullDesc: "forces a class change\n\nSYNTAX:\n\tFORCECLASS <i>CLASSID</i>\nWHERE:\n\tCLASSID
      is the identification number of the class\n\nNOTE:\n\tCheck \"CLASSLIST\" to
      display a list of class IDs."
  - name: GOTO
    shortDesc: move to the selected place
    fullDesc: "move to the selected place\n\nSYNTAX:\n\tGOTO <i>ROOMID</i>\nWHERE:\n\tROOMID
      is the identification number of the room\n\nNOTE:\n\tA full list of identification
      numbers is available mainly for testers."
  - name: RANGE
    shortDesc: unlocks access to the shooting range
    fullDesc: "unlocks access to the shooting range\n\nSYNTAX:\n\tRANGE"
  - name: ROUNDRESTART
    shortDesc: force round restart
    fullDesc: "force round restart\n\nSYNTAX:\n\tROUNDRESTART"
  - name: CONFIG
    shortDesc: configuration file commands
    fullDesc: "Configuration file commands:\n\nSYNTAX:\n\tCONFIG <i>CMD</i>\n\nWHERE:\n\tCMD
      is one of the following arguments:\n\n\t-<b>RELOAD</b> or <b>RLD</b> or <b>R</b>\n\t\tReloads
      the configuration file\n\n\t-<b>PATH</b>\n\t\tDisplays the configuration file
      path\n\n\t-<b>VALUE <i>KEY</i></b>\n\t\tDisplays <i>KEY</i> value"
  txt: {fileID: 600}
  cmdField: {fileID: 589}
